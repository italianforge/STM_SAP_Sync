# Environment configuration
ENV=development

# Database URLs
POSTGRES_URL=postgresql://user:password@localhost:5432/database
SAP_DB_URL=mssql+pyodbc://user:password@server/database?driver=ODBC+Driver+17+for+SQL+Server

# DEPOSYTA (SQL Server — DBDATA @ 192.168.0.5)
DEPOSYTA_DB_SERVER=192.168.0.5
DEPOSYTA_DB_DATABASE=DBDATA
DEPOSYTA_DB_USERNAME=
DEPOSYTA_DB_PASSWORD=
# DEPOSYTA_DB_DRIVER=SQL Server
# DEPOSYTA_DB_URL=mssql+pyodbc://...  # alternativa: URL completo al posto dei campi sopra

# MODULA (SQL Server — SYSTOREDB @ istanza MODULA su 192.168.0.5)
MODULA_DB_SERVER=192.168.0.5\MODULA
MODULA_DB_DATABASE=SYSTOREDB
MODULA_DB_USERNAME=
MODULA_DB_PASSWORD=
# MODULA_DB_DRIVER=SQL Server
# MODULA_DB_PORT=1433  # se SQL Browser non risponde, imposta la porta TCP dell'istanza MODULA
# MODULA_DB_URL=mssql+pyodbc://...  # alternativa: URL completo al posto dei campi sopra

# Logging configuration
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_TO_CONSOLE=true
LOG_DIR=logs
LOG_FILE_MAX_SIZE=10485760
LOG_FILE_BACKUP_COUNT=5

# Encryption (must match STM_Scheduler ENCRYPTION_KEY — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-fernet-key-here

# Sync configuration
BATCH_SIZE=1000
MAX_RETRIES=3

# Machine-to-machine auth token for STM_Scheduler API (must match STM_Scheduler INTERNAL_SERVICE_TOKEN)
INTERNAL_SERVICE_TOKEN=
